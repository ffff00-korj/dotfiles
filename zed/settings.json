// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "hide_gitignore": false
  },
  "languages": {
    "Python": {
      "language_servers": ["pyright", "ruff", "python-refactoring"],
      "format_on_save": "on",
      "formatter": [
        {
          "code_actions": {
            "source.organizeImports.ruff": true
          }
        },
        {
          "language_server": {
            "name": "ruff"
          }
        }
      ]
    }
  },
  "lsp": {
    "pyright": {
      "settings": {
        "python.analysis": {
          "diagnosticMode": "openFileOnly",
          "typeCheckingMode": "standart"
        }
      }
    }
  },
  "ssh_connections": [
    {
      "host": "mgnsrv",
      "username": "ilya",
      "projects": [
        {
          "paths": ["~/repo"]
        }
      ]
    }
  ],
  "assistant": {
    "default_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:3b"
    },
    "version": "2"
  },
  "features": {
    "edit_prediction_provider": "zed"
  },
  "chat_panel": {
    "dock": "right"
  },
  "vim_mode": true,
  "use_system_clipboard": "never",
  "vim": { "use_system_clipboard": "never" },
  "ui_font_size": 13,
  "buffer_font_size": 13,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font"
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "JetBrains New Dark"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "relative_line_numbers": true,
  "vertical_scroll_margin": 15,
  "projects_online_by_default": false,
  "preferred_line_length": 79
}
