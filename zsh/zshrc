# system environment variables
export GIT_DISCOVERY_ACROSS_FILESYSTEM=1
export LC_ALL=en_US.UTF-8
export LANG=ru_RU.UTF-8

# local/bin to the PATH
export PATH=$PATH:~/.local/bin
# go/bin to the PATH
export PATH=$PATH:~/go/bin

# oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="refined"
source ~/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh
plugins=(git sudo)
source $ZSH/oh-my-zsh.sh

# pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init - bash)"
# autoactivate virtualenv in python projects
eval "$(pyenv virtualenv-init -)"

# The following lines have been added by Docker Desktop to enable Docker CLI completions.
fpath=(~/.docker/completions $fpath)
autoload -Uz compinit
compinit

# Additional setup options for work
if [ -f ~/.worksetup ]; then
    source ~/.worksetup
else
    echo '# your setup options here'> ~/.worksetup
    chmod 600 ~/.worksetup
    echo "~/.worksetup file created"
fi

# load secret from pass
load_secret() {
    secret=$(pass "$1" 2>/dev/null) || {
        echo "Error: Failed to load secret '$1'" >&2
        return 1
    }
    echo -n "${secret%$'\n'}"
}
